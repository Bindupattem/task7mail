pipeline {
    agent any

    environment {
        // Docker Hub credentials stored in Jenkins credentials (username/password)
        DOCKER_HUB_CREDENTIALS = 'docker-hub-cred-id' // Replace with your Jenkins credentials ID
        DOCKER_IMAGE = 'docker build -t bindusravya/task7:latest project/'// Replace with your Docker Hub username
        RECIPIENT = 'sravyapattem371@gmail.com' // Your email
    }

    stages {

        stage('Checkout Code') {
            steps {
                git url: 'https://github.com/Bindupattem/task7mail.git', branch: 'main'
                echo 'Code checkout successful'
                script {
                    try {
                        mail to: "${RECIPIENT}",
                             subject: 'Checkout Success',
                             body: 'Code pulled from GitHub successfully'
                    } catch (Exception e) {
                        echo "Mail failed"
                    }
                }
            }
        }

        stage('Build') {
            steps {
                echo 'Build Stage Successful'
                script {
                    try {
                        mail to: "${RECIPIENT}",
                             subject: 'Build Success',
                             body: 'Build stage completed successfully'
                    } catch (Exception e) {
                        echo "Mail failed"
                    }
                }
            }
        }

        stage('Test') {
            steps {
                echo 'Test Stage Successful'
                script {
                    try {
                        mail to: "${RECIPIENT}",
                             subject: 'Test Success',
                             body: 'Test stage completed successfully'
                    } catch (Exception e) {
                        echo "Mail failed"
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t ${DOCKER_IMAGE} .'  // builds from repo root where Dockerfile is
                script {
                    try {
                        mail to: "${RECIPIENT}",
                             subject: 'Docker Build Success',
                             body: "Docker image ${DOCKER_IMAGE} built successfully"
                    } catch (Exception e) {
                        echo "Mail failed"
                    }
                }
            }
        }

        stage('Docker Push') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: "${DOCKER_HUB_CREDENTIALS}", 
                                                      usernameVariable: 'DOCKER_USER', 
                                                      passwordVariable: 'DOCKER_PASS')]) {
                        sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                        sh 'docker push ${DOCKER_IMAGE}'
                    }
                    try {
                        mail to: "${RECIPIENT}",
                             subject: 'Docker Push Success',
                             body: "Docker image ${DOCKER_IMAGE} pushed successfully"
                    } catch (Exception e) {
                        echo "Mail failed"
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker rm -f task7 || true
                docker run -d -p 8990:80 --name task7 ${DOCKER_IMAGE}
                '''
                script {
                    try {
                        mail to: "${RECIPIENT}",
                             subject: 'Deployment Success',
                             body: 'Application deployed successfully'
                    } catch (Exception e) {
                        echo "Mail failed"
                    }
                }
            }
        }

        stage('Check Node') {
            steps {
                sh 'echo Running on node: $NODE_NAME'
            }
        }
    }

    post {
        always {
            script {
                try {
                    mail to: "${RECIPIENT}",
                         subject: "Pipeline Completed - ${currentBuild.currentResult}",
                         body: "Your pipeline #${env.BUILD_NUMBER} finished with status: ${currentBuild.currentResult}."
                } catch (Exception e) {
                    echo "Mail failed"
                }
            }
        }

        failure {
            script {
                try {
                    mail to: "${RECIPIENT}",
                         subject: "Pipeline Failed",
                         body: "Something failed in pipeline #${env.BUILD_NUMBER}"
                } catch (Exception e) {
                    echo "Mail failed"
                }
            }
        }
    }
}
